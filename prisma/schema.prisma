generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// AUTH / USERS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  SALES
  FINANCE
}

model Profile {
  id        String   @id @db.Uuid
  name      String
  email     String   @unique
  role      Role     @default(SALES)
  avatarUrl String?  @map("avatar_url")
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sales            Sale[]
  movements        StockEntry[]
  commissions      Commission[]
  cashRegisterOpen CashRegister[] @relation("CashOpenedBy")
  cashRegisterClose CashRegister[] @relation("CashClosedBy")
  cashEntries      CashRegisterEntry[]

  @@map("profiles")
}

// ─────────────────────────────────────────────
// LOOKUP / CATALOGOS
// ─────────────────────────────────────────────

model Category {
  id       String  @id @default(cuid())
  name     String  @unique
  parentId String? @map("parent_id")

  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children Category[] @relation("CategoryParent")
  products Product[]

  @@map("categories")
}

model Collection {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]

  @@map("collections")
}

model Brand {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]

  @@map("brands")
}

model FinancialCategory {
  id      String          @id @default(cuid())
  name    String
  type    EntryType
  entries FinancialEntry[]

  @@map("financial_categories")
}

model CostCenter {
  id      String          @id @default(cuid())
  name    String          @unique
  entries FinancialEntry[]

  @@map("cost_centers")
}

// ─────────────────────────────────────────────
// SUPPLIER
// ─────────────────────────────────────────────

model Supplier {
  id             String   @id @default(cuid())
  name           String
  cnpj           String?  @unique
  phone          String?
  whatsapp       String?
  instagram      String?
  email          String?
  street         String?
  city           String?
  state          String?
  zipCode        String?  @map("zip_code")
  paymentTerms   String?  @map("payment_terms")
  avgLeadDays    Int?     @map("avg_lead_days")
  notes          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  products  Product[]
  purchases Purchase[]

  @@map("suppliers")
}

// ─────────────────────────────────────────────
// PRODUCT
// ─────────────────────────────────────────────

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model Product {
  id           String        @id @default(cuid())
  name         String
  sku          String        @unique
  barcode      String?       @unique
  categoryId   String?       @map("category_id")
  collectionId String?       @map("collection_id")
  brandId      String?       @map("brand_id")
  supplierId   String?       @map("supplier_id")
  material     String?
  plating      String?
  color        String?
  stone        String?
  weightGrams  Decimal?      @map("weight_grams") @db.Decimal(8, 2)
  lengthCm     Decimal?      @map("length_cm") @db.Decimal(8, 2)
  size         String?
  description  String?
  notes        String?
  videoUrl     String?       @map("video_url")
  status       ProductStatus @default(ACTIVE)
  isFeatured   Boolean       @default(false) @map("is_featured")
  isExclusive  Boolean       @default(false) @map("is_exclusive")

  // Garantia
  warrantyMonths     Int?    @map("warranty_months")
  warrantyType       String? @map("warranty_type")
  warrantyConditions String? @map("warranty_conditions")

  // Custos
  costPrice    Decimal  @default(0) @map("cost_price") @db.Decimal(10, 2)
  freightCost  Decimal  @default(0) @map("freight_cost") @db.Decimal(10, 2)
  taxCost      Decimal  @default(0) @map("tax_cost") @db.Decimal(10, 2)
  commission   Decimal  @default(0) @db.Decimal(10, 2)
  packaging    Decimal  @default(0) @db.Decimal(10, 2)
  otherCosts   Decimal  @default(0) @map("other_costs") @db.Decimal(10, 2)

  // Preços
  salePrice        Decimal  @default(0) @map("sale_price") @db.Decimal(10, 2)
  promoPrice       Decimal? @map("promo_price") @db.Decimal(10, 2)
  wholesalePrice   Decimal? @map("wholesale_price") @db.Decimal(10, 2)
  vipPrice         Decimal? @map("vip_price") @db.Decimal(10, 2)
  marketplacePrice Decimal? @map("marketplace_price") @db.Decimal(10, 2)
  resellerPrice    Decimal? @map("reseller_price") @db.Decimal(10, 2)

  // Estoque
  currentStock  Int     @default(0) @map("current_stock")
  minStock      Int     @default(0) @map("min_stock")
  location      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  category      Category?      @relation(fields: [categoryId], references: [id])
  collection    Collection?    @relation(fields: [collectionId], references: [id])
  brand         Brand?         @relation(fields: [brandId], references: [id])
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  images        ProductImage[]
  stockEntries  StockEntry[]
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]
  wishlistItems WishlistItem[]
  warranties    Warranty[]
  serviceOrders ServiceOrder[]

  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String  @map("product_id")
  url       String
  order     Int     @default(0)
  isPrimary Boolean @default(false) @map("is_primary")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ─────────────────────────────────────────────
// STOCK
// ─────────────────────────────────────────────

enum StockMovementType {
  IN
  OUT
  ADJUST
  INVENTORY
  TRANSFER
  CONSIGNMENT_IN
  CONSIGNMENT_OUT
  DAMAGE
  LOSS
  RETURN
  RESERVATION
}

model StockEntry {
  id            String            @id @default(cuid())
  productId     String            @map("product_id")
  type          StockMovementType
  quantity      Int
  previousQty   Int               @map("previous_qty")
  newQty        Int               @map("new_qty")
  reason        String?
  lot           String?
  referenceId   String?           @map("reference_id")
  locationFrom  String?           @map("location_from")
  locationTo    String?           @map("location_to")
  isConsignment Boolean           @default(false) @map("is_consignment")
  isDamaged     Boolean           @default(false) @map("is_damaged")
  userId        String?           @map("user_id") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at")

  product Product  @relation(fields: [productId], references: [id])
  user    Profile? @relation(fields: [userId], references: [id])

  @@map("stock_entries")
}

// ─────────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────────

model Customer {
  id             String    @id @default(cuid())
  name           String
  cpf            String?   @unique
  birthDate      DateTime? @map("birth_date") @db.Date
  phone          String?
  whatsapp       String?
  instagram      String?
  email          String?
  street         String?
  city           String?
  state          String?
  zipCode        String?   @map("zip_code")
  notes          String?
  active         Boolean   @default(true)
  isVip          Boolean   @default(false) @map("is_vip")
  cashback       Decimal   @default(0) @db.Decimal(10, 2)
  points         Int       @default(0)
  lastPurchaseAt DateTime? @map("last_purchase_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  sales         Sale[]
  wishlistItems WishlistItem[]
  specialDates  SpecialDate[]
  warranties    Warranty[]
  serviceOrders ServiceOrder[]

  @@map("customers")
}

model WishlistItem {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("wishlist_items")
}

model SpecialDate {
  id          String   @id @default(cuid())
  customerId  String   @map("customer_id")
  description String
  date        DateTime @db.Date
  createdAt   DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("special_dates")
}

// ─────────────────────────────────────────────
// PURCHASE (Compras)
// ─────────────────────────────────────────────

enum PurchaseStatus {
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

model Purchase {
  id            String         @id @default(cuid())
  number        String         @unique
  supplierId    String         @map("supplier_id")
  status        PurchaseStatus @default(ORDERED)
  invoiceNumber String?        @map("invoice_number")
  invoiceDate   DateTime?      @map("invoice_date") @db.Date
  expectedAt    DateTime?      @map("expected_at") @db.Date
  receivedAt    DateTime?      @map("received_at")
  total         Decimal        @db.Decimal(10, 2)
  paymentStatus PaymentStatus  @default(PENDING) @map("payment_status")
  notes         String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  supplier       Supplier        @relation(fields: [supplierId], references: [id])
  items          PurchaseItem[]
  financialEntry FinancialEntry?

  @@map("purchases")
}

model PurchaseItem {
  id         String  @id @default(cuid())
  purchaseId String  @map("purchase_id")
  productId  String  @map("product_id")
  quantity   Int
  unitCost   Decimal @map("unit_cost") @db.Decimal(10, 2)
  total      Decimal @db.Decimal(10, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

// ─────────────────────────────────────────────
// SALE / PDV
// ─────────────────────────────────────────────

enum SaleStatus {
  QUOTE
  ORDER
  PRESALE
  PENDING
  COMPLETED
  CANCELLED
}

enum SaleChannel {
  INSTORE
  WHATSAPP
  INSTAGRAM
  ONLINE
  CATALOG
  OTHER
}

enum PaymentMethod {
  PIX
  CASH
  CREDIT
  DEBIT
  BOLETO
  OTHER
}

model Sale {
  id         String      @id @default(cuid())
  number     String      @unique
  customerId String?     @map("customer_id")
  sellerId   String?     @map("seller_id") @db.Uuid
  status     SaleStatus  @default(COMPLETED)
  channel    SaleChannel @default(INSTORE)
  subtotal   Decimal     @db.Decimal(10, 2)
  discount   Decimal     @default(0) @db.Decimal(10, 2)
  freight    Decimal     @default(0) @db.Decimal(10, 2)
  total      Decimal     @db.Decimal(10, 2)
  couponCode String?     @map("coupon_code")
  notes      String?
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  customer       Customer?      @relation(fields: [customerId], references: [id])
  seller         Profile?       @relation(fields: [sellerId], references: [id])
  items          SaleItem[]
  payments       Payment[]
  financialEntry FinancialEntry?
  commission     Commission?

  @@map("sales")
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String  @map("sale_id")
  productId String  @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  discount  Decimal @default(0) @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

model Payment {
  id           String        @id @default(cuid())
  saleId       String        @map("sale_id")
  method       PaymentMethod
  amount       Decimal       @db.Decimal(10, 2)
  installments Int           @default(1)
  cardBrand    String?       @map("card_brand")
  createdAt    DateTime      @default(now()) @map("created_at")

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─────────────────────────────────────────────
// FINANCIAL
// ─────────────────────────────────────────────

enum EntryType {
  INCOME
  EXPENSE
}

enum EntryStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum ReferenceType {
  SALE
  PURCHASE
  MANUAL
  COMMISSION
  SERVICE
}

model FinancialEntry {
  id            String        @id @default(cuid())
  type          EntryType
  categoryId    String?       @map("category_id")
  costCenterId  String?       @map("cost_center_id")
  description   String
  amount        Decimal       @db.Decimal(10, 2)
  dueDate       DateTime      @map("due_date") @db.Date
  paidAt        DateTime?     @map("paid_at")
  status        EntryStatus   @default(PENDING)
  referenceType ReferenceType @default(MANUAL) @map("reference_type")
  referenceId   String?       @map("reference_id")
  saleId        String?       @unique @map("sale_id")
  purchaseId    String?       @unique @map("purchase_id")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  category   FinancialCategory? @relation(fields: [categoryId], references: [id])
  costCenter CostCenter?        @relation(fields: [costCenterId], references: [id])
  sale       Sale?              @relation(fields: [saleId], references: [id])
  purchase   Purchase?          @relation(fields: [purchaseId], references: [id])

  @@map("financial_entries")
}

// ─────────────────────────────────────────────
// COUPONS
// ─────────────────────────────────────────────

enum CouponType {
  PERCENTAGE
  FIXED
}

model Coupon {
  id        String     @id @default(cuid())
  code      String     @unique
  type      CouponType
  value     Decimal    @db.Decimal(10, 2)
  minAmount Decimal?   @map("min_amount") @db.Decimal(10, 2)
  maxUses   Int?       @map("max_uses")
  usedCount Int        @default(0) @map("used_count")
  active    Boolean    @default(true)
  expiresAt DateTime?  @map("expires_at")
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("coupons")
}

// ─────────────────────────────────────────────
// CAIXA (Cash Register)
// ─────────────────────────────────────────────

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum CashEntryType {
  OPENING
  CLOSING
  SANGRIA
  SUPRIMENTO
  SALE
  PAYMENT_IN
  ADJUSTMENT
}

model CashRegister {
  id              String             @id @default(cuid())
  openedAt        DateTime           @default(now()) @map("opened_at")
  closedAt        DateTime?          @map("closed_at")
  openingBalance  Decimal            @map("opening_balance") @db.Decimal(10, 2)
  closingBalance  Decimal?           @map("closing_balance") @db.Decimal(10, 2)
  expectedBalance Decimal?           @map("expected_balance") @db.Decimal(10, 2)
  difference      Decimal?           @db.Decimal(10, 2)
  status          CashRegisterStatus @default(OPEN)
  notes           String?
  openedById      String             @map("opened_by_id") @db.Uuid
  closedById      String?            @map("closed_by_id") @db.Uuid

  openedBy Profile  @relation("CashOpenedBy", fields: [openedById], references: [id])
  closedBy Profile? @relation("CashClosedBy", fields: [closedById], references: [id])
  entries  CashRegisterEntry[]

  @@map("cash_registers")
}

model CashRegisterEntry {
  id          String        @id @default(cuid())
  registerId  String        @map("register_id")
  type        CashEntryType
  amount      Decimal       @db.Decimal(10, 2)
  description String
  createdAt   DateTime      @default(now()) @map("created_at")
  createdById String        @map("created_by_id") @db.Uuid

  register    CashRegister @relation(fields: [registerId], references: [id])
  createdBy   Profile      @relation(fields: [createdById], references: [id])

  @@map("cash_register_entries")
}

// ─────────────────────────────────────────────
// GARANTIAS (Warranties)
// ─────────────────────────────────────────────

enum WarrantyStatus {
  ACTIVE
  CLAIMED
  EXPIRED
  VOIDED
}

model Warranty {
  id          String         @id @default(cuid())
  productId   String         @map("product_id")
  customerId  String         @map("customer_id")
  saleId      String?        @map("sale_id")
  issueDate   DateTime       @default(now()) @map("issue_date") @db.Date
  expiryDate  DateTime       @map("expiry_date") @db.Date
  status      WarrantyStatus @default(ACTIVE)
  defectDesc  String?        @map("defect_desc")
  resolution  String?
  notes       String?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  product  Product         @relation(fields: [productId], references: [id])
  customer Customer        @relation(fields: [customerId], references: [id])
  photos   WarrantyPhoto[]

  @@map("warranties")
}

model WarrantyPhoto {
  id         String   @id @default(cuid())
  warrantyId String   @map("warranty_id")
  url        String
  photoType  String   @map("photo_type") // "before" | "after"
  createdAt  DateTime @default(now()) @map("created_at")

  warranty Warranty @relation(fields: [warrantyId], references: [id], onDelete: Cascade)

  @@map("warranty_photos")
}

// ─────────────────────────────────────────────
// ASSISTÊNCIA TÉCNICA (Service Orders)
// ─────────────────────────────────────────────

enum ServiceType {
  POLISHING
  CLASP_CHANGE
  STONE_CHANGE
  ADJUSTMENT
  PLATING
  REPAIR
  OTHER
}

enum ServiceStatus {
  RECEIVED
  IN_PROGRESS
  WAITING_PARTS
  READY
  DELIVERED
  CANCELLED
}

model ServiceOrder {
  id            String        @id @default(cuid())
  number        Int           @default(autoincrement())
  customerId    String        @map("customer_id")
  productId     String?       @map("product_id")
  productName   String?       @map("product_name")
  type          ServiceType
  description   String
  status        ServiceStatus @default(RECEIVED)
  estimatedDate DateTime?     @map("estimated_date") @db.Date
  completedDate DateTime?     @map("completed_date") @db.Date
  price         Decimal?      @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  customer Customer       @relation(fields: [customerId], references: [id])
  product  Product?       @relation(fields: [productId], references: [id])
  photos   ServicePhoto[]

  @@map("service_orders")
}

model ServicePhoto {
  id        String   @id @default(cuid())
  serviceId String   @map("service_id")
  url       String
  photoType String   @map("photo_type") // "before" | "after"
  createdAt DateTime @default(now()) @map("created_at")

  service ServiceOrder @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("service_photos")
}

// ─────────────────────────────────────────────
// COMISSÕES
// ─────────────────────────────────────────────

enum CommissionStatus {
  PENDING
  PAID
  CANCELLED
}

// ─────────────────────────────────────────────
// INTEGRATIONS
// ─────────────────────────────────────────────

model Integration {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  enabled   Boolean  @default(false)
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("integrations")
}

model Commission {
  id       String           @id @default(cuid())
  saleId   String           @unique @map("sale_id")
  sellerId String           @map("seller_id") @db.Uuid
  amount   Decimal          @db.Decimal(10, 2)
  rate     Decimal          @db.Decimal(5, 2)
  status   CommissionStatus @default(PENDING)
  paidAt   DateTime?        @map("paid_at")
  createdAt DateTime        @default(now()) @map("created_at")

  sale   Sale    @relation(fields: [saleId], references: [id])
  seller Profile @relation(fields: [sellerId], references: [id])

  @@map("commissions")
}
